{
  "name": "gg-ai",
  "version": "0.1.0",
  "private": true,
  "description": "线束 MES — Next.js + Prisma(PostgreSQL) + Server Actions；生产构建含 prisma generate / db push",
  "main": "main.js",
  "scripts": {
    "dev": "node scripts/print-dev-url.mjs && next dev -p 3456 -H 127.0.0.1",
    "open:dev": "start http://127.0.0.1:3456",
    "dev:3000": "next dev -p 3000 -H 127.0.0.1",
    "build": "prisma generate && prisma db push && next build",
    "start": "next start -p 3456 -H 127.0.0.1",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "check:all": "pnpm run type-check && pnpm run lint",
    "db:check": "node scripts/check-db-counts.cjs",
    "build-exe": "electron-builder --win",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.mes.system",
    "productName": "MES系统",
    "files": [
      "main.js"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@prisma/client": "6.19.0",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.0.1",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "prisma": "6.19.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
